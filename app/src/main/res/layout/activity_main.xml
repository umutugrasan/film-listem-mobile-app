<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- Ust bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface_dark"
        app:titleTextColor="@color/text_primary"
        app:title="@string/ana_baslik" />

    <!-- Liste alani -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFilmler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="8dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false" />

        <!-- Bos liste mesaji -->
        <TextView
            android:id="@+id/tvBosListe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/bos_liste"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Yeni film ekle butonu (FAB) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabEkle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:contentDescription="@string/yeni_film_ekle"
            android:src="@drawable/ic_add"
            app:backgroundTint="@color/accent_yellow"
            app:tint="@color/black" />

    </FrameLayout>

</LinearLayout>
