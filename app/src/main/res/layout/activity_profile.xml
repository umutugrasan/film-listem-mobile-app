<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/bg_dark">

    <!-- Ust bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnGeri"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/geri" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/profil_baslik"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bilgi_ad"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etAd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/ad_hint"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:inputType="text"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/bilgi_favori"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etFavoriTur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/favori_tur_hint"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:inputType="text"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/bilgi_hakkimda"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etHakkimda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hakkimda_hint"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top" />

            <Button
                android:id="@+id/btnKaydet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/kaydet"
                android:textColor="@color/black"
                android:backgroundTint="@color/accent_yellow" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
